---
import Layout from '../layouts/Layout.astro';
import PostGrid from '../components/blog/PostGrid.jsx';
import { getBlogPosts, paginatePosts } from '../lib/blog.ts';

const allPosts = await getBlogPosts();
const requestedPage = Number(Astro.url.searchParams.get('page') ?? '1');
const { items: posts, currentPage, totalPages } = paginatePosts(allPosts, requestedPage);
---

<Layout title="Que Sono | Home">
  <section class="hero">
    <h1>Que Sono — Blog</h1>
    <p>
      Um espaço para ideias, histórias e conteúdo publicado pelo Keystatic.
    </p>
    <div class="hero-actions">
      <a class="button-link" href="/">Atualizar página</a>
    </div>
  </section>

  <h2 class="section-title">Posts publicados</h2>
  <div>
    <PostGrid client:load posts={posts} pagination={{ currentPage, totalPages }} />
  </div>
</Layout>
