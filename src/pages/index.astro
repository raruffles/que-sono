---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const posts = await getCollection('posts', (post) => post.data.status === 'published');
---

<Layout title="Keystatic & Astro's Content Collections">
  <section class="hero">
    <h1>Que Sono — Blog</h1>
    <p>
      Um espaço para ideias, histórias e conteúdo publicado pelo Keystatic.
    </p>
    <div class="hero-actions">
      <a class="button-link" href="/">Atualizar página</a>
    </div>
  </section>

  <h2 class="section-title">Posts publicados</h2>
  <ul class="posts-grid">
    {
      posts.map(post => (
        <li class="post-card">
          <a href={`/posts/${post.id}`}>
            <h3 class="post-card-title">{post.data.title}</h3>
            <p class="post-card-meta">Ler artigo completo</p>
          </a>
        </li>
      ))
    }
  </ul>
</Layout>
